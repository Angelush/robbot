# === Discord ===
DISCORD_TOKEN=your_discord_bot_token_here

# === LLM Backends ===
# Primary: mistral | groq | ollama
# Fallback: groq | ollama | mistral
LLM_PRIMARY=mistral
LLM_FALLBACK=groq

# Mistral free tier (https://console.mistral.ai — no credit card needed)
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest

# Groq free tier (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Ollama local (only if running locally)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# === Paths ===
# Only needed for build_vectordb.py (not at runtime)
ARCHIVE_PATH=C:\Users\Angelus\My Drive\IA\Rob

# === Tuning ===
LLM_MAX_TOKENS=600
LLM_TEMPERATURE=0.7
USER_COOLDOWN_SECONDS=10
LLM_MAX_REQUESTS_PER_SECOND=0.9
RAG_TOP_K=8
RAG_MAX_VIDEOS=5
RAG_MIN_RELEVANCE=0.3
